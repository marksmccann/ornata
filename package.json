{
    "name": "ornata",
    "private": true,
    "type": "module",
    "description": "Ornata is a type-safe framework for building and distributing interactive UI components on HTML-first applications",
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "build": "lerna run build",
        "dev": "lerna run dev",
        "start:docs": "npm run dev -w ornata-docs",
        "test": "lerna run test",
        "test:watch": "lerna run test:watch",
        "prerelease": "lerna run test --no-private && lerna run build --no-private",
        "release": "lerna version",
        "postrelease": "lerna publish from-git && git push --follow-tags",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "commit": "cz",
        "prepare": "husky"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/marksmccann/ornata.git"
    },
    "keywords": [
        "ornata",
        "progressive",
        "enhancement",
        "framework",
        "HTML-first",
        "Server-rendered"
    ],
    "author": "Mark McCann",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/marksmccann/ornata/issues"
    },
    "homepage": "https://github.com/marksmccann/ornata#readme",
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.2",
        "@commitlint/config-conventional": "^20.4.2",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "husky": "^9.1.7",
        "jsdom": "^28.1.0",
        "lerna": "^9.0.0",
        "prettier": "^3.0.0"
    }
}
