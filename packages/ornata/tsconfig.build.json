{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "composite": false,
        "declaration": true,
        "emitDeclarationOnly": true,
        "incremental": false,
        "noEmit": false,
        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["src/**/*.test.ts", "dist"]
}
