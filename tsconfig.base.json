{
    "compilerOptions": {
        "target": "ESNext",
        "strict": true,
        "noEmit": true,
        "moduleDetection": "force",
        "skipLibCheck": true,
        "verbatimModuleSyntax": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true
    }
}
